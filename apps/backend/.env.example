# =========================
# Database
# =========================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/baby_tracker

# =========================
# Firebase
# =========================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json

# =========================
# Cloudflare R2
# =========================
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=baby-tracker

# =========================
# Gemma AI Service
# =========================
GEMMA_API_URL=http://localhost:8080
GEMMA_API_KEY=your-gemma-api-key

# =========================
# Gemini AI Service
# Get your API key from: https://makersuite.google.com/app/apikey
# =========================
GEMINI_API_KEY=your-gemini-api-key

# =========================
# Notification Scheduler
# =========================
NOTIFICATION_TEST_MODE=True

# =========================
# App
# =========================
# Set to "production" in prod environments
ENVIRONMENT=development

# =========================
# Security — CORS
# Comma-separated list of allowed origins.
# In development the default allows localhost.
# In production, set this to your actual frontend origins.
# =========================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081

# =========================
# Security — Rate Limiting
# =========================
RATE_LIMIT_PER_MINUTE=60
AI_RATE_LIMIT_PER_MINUTE=10
AUTH_RATE_LIMIT_PER_MINUTE=20

# =========================
# Observability — Sentry
# Get your DSN from: https://sentry.io
# Leave empty to disable Sentry (development default).
# =========================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
